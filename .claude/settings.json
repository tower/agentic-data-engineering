{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "AskUserQuestion"
    ]
  },
  "enabledMcpjsonServers": [
    "tower-mcp"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-secret-leaks.sh"
          }
        ]
      }
    ]
  }
}
